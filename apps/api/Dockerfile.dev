FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app

ENV PYTHONPATH=/app/src \
    PYTHONUNBUFFERED=1

COPY pyproject.toml README.md ./
RUN uv sync --no-install-project

COPY src ./src

EXPOSE 8000

CMD ["uv", "run", "--no-sync", "uvicorn", "morphix_api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "src"]