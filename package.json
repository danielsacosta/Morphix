{
  "name": "morphix",
  "version": "0.1.0",
  "private": true,
  "description": "Morphix monorepo for asynchronous file conversion on AWS.",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "build": "npm run build -w apps/frontend",
    "dev": "npm run dev -w apps/frontend",
    "lint": "npm run lint -w apps/frontend",
    "test": "npm run test:python",
    "test:python": "uv run --group dev pytest",
    "test:api": "uv run --group dev pytest apps/api/tests",
    "test:worker": "uv run --group dev pytest apps/worker/tests"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  }
}
